{
  "name": "@munigan/wow-combatlog-parser",
  "version": "0.3.2",
  "description": "Streaming parser for World of Warcraft WotLK 3.3.5 combat logs",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "pnpm run build",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "bench": "node --expose-gc --import tsx scripts/bench.ts",
    "bench:micro": "vitest bench"
  },
  "keywords": [
    "wow",
    "warcraft",
    "combat-log",
    "parser",
    "wotlk"
  ],
  "license": "MIT",
  "author": "diego3g",
  "repository": {
    "type": "git",
    "url": "https://github.com/munigan/wow-combatlog-parser"
  },
  "homepage": "https://github.com/munigan/wow-combatlog-parser#readme",
  "bugs": {
    "url": "https://github.com/munigan/wow-combatlog-parser/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "tsx": "4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
